{
  "name": "industrial-cx-service-analytics-lab",
  "version": "1.0.0",
  "private": true,
  "description": "Simulated industrial CX analytics, telemetry simulation and service-risk scoring portfolio lab.",
  "scripts": {
    "test": "npm run test:node && npm run test:cx-analyst && npm run test:industrial-ai && npm run test:prod-sim",
    "test:node": "node scripts/validate-data.mjs",
    "test:cx-analyst": "python3 -m unittest discover cx-analyst-lab/tests",
    "test:industrial-ai": "python3 -m unittest discover industrial-cx-ai-lab/tests",
    "test:prod-sim": "python3 -m unittest discover production-sim-stack/tests",
    "run:industrial-ai": "python3 industrial-cx-ai-lab/src/run_pipeline.py",
    "run:prod-sim": "python3 production-sim-stack/src/orchestrate.py",
    "run:mqtt-sim": "python3 production-sim-stack/src/mqtt_simulator.py",
    "run:ml-baseline": "python3 ml-baseline/train_model.py",
    "validate": "npm test"
  },
  "engines": {
    "node": ">=18"
  }
}
