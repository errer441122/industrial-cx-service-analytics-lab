{
  "title": "Industrial CX Service Risk Monitor",
  "schemaVersion": 39,
  "tags": ["portfolio", "industrial-iot", "cx-risk"],
  "panels": [
    {
      "type": "timeseries",
      "title": "Telemetry anomaly score by bike family",
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "from(bucket: \"portfolio\") |> range(start: -24h) |> filter(fn: (r) => r._measurement == \"ducati_service_risk\")"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Human review queue",
      "datasource": "SQLite export",
      "description": "Count of records where predicted churn/service risk exceeds the advisory threshold."
    }
  ]
}
